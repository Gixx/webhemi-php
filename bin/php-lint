#!/bin/bash
# PHP Lint script - checks all PHP files in src directory
# Displays only error count and files with syntax errors

PROJECT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
SRC_DIR="$PROJECT_DIR/src"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Counters
total_files=0
error_files=0
errors=()

# Process all PHP files
while IFS= read -r file; do
    ((total_files++))
    output=$(php -l "$file" 2>&1)
    if [[ $? -ne 0 ]]; then
        ((error_files++))
        errors+=("$output")
    fi
done < <(find "$SRC_DIR" -type f -name "*.php")

# Display results
echo -e "${YELLOW}Checked $total_files PHP files${NC}"

if [[ $error_files -eq 0 ]]; then
    echo -e "${GREEN}✓ No syntax errors found${NC}"
    exit 0
else
    echo -e "${RED}✗ $error_files file(s) with syntax errors:${NC}"
    printf '%s\n' "${errors[@]}"
    exit 1
fi
