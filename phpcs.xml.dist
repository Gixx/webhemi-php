<?xml version="1.0"?>
<ruleset name="WebHemi">
    <rule ref="PSR12"/>
    <rule ref="Generic.Files.LineLength">
        <severity>5</severity>
        <properties>
            <property name="lineLimit" value="120"/>
            <property name="absoluteLineLimit" value="200"/>
        </properties>
    </rule>
    <file>src</file>
</ruleset>
